pipeline {
  agent any
  
  tools {
    jdk 'jdk25'
  }
  
  environment {
    SCANNER_HOME = tool 'sonar'
    ECR_URL = "224075521027.dkr.ecr.us-east-1.amazonaws.com"
    ECR_REPO = "zomato-app"
    DOCKER_IMAGE = "rahul917797/zomato"
    REGION = "us-east-1"
    DOCKER_TAG = "latest"
  }
  
  stages{
    stage('Git-Checkout'){
		  steps{
      git branch: 'master', url: 'https://github.com/Rahul917797/ArgoCD-Maven.git'
      }
		}
		
		stage('Build') {
          steps {
            dir('spring-boot-app') {
              sh 'mvn clean install'
             }
           }
        }
		
		stage('SonarQube Analysis') {
          steps {
            withSonarQubeEnv('sonar') {
              dir('spring-boot-app') {
              sh """
              $SCANNER_HOME/bin/sonar-scanner \
              -Dsonar.projectName=zomato-app \
              -Dsonar.projectKey=zomato-app \
              -Dsonar.sources=.
              """
               }
             }
           }
        }
			
			stage('Login to ECR'){
			  steps{
				  script{
					  withAWS(credentialsId: 'aws-creds', region: "${REGION}"){
						  sh '''
							aws ecr get-login-password --region $REGION | docker login --username AWS --password-stdin $ECR_URL
							'''
						}
					}
				}
			}
			
			stage('Tag and Push to ECR'){
			  steps{
				  script{
					  sh '''
					  docker tag $DOCKER_IMAGE:$DOCKER_TAG $ECR_URL/$ECR_REPO:$DOCKER_TAG
                      docker push $ECR_URL/$ECR_REPO:$DOCKER_TAG
					  '''
					}
				}
			}
			
			stage('Deploy to Container'){
			  steps{
				  sh 'docker rm -f zomato-app || true'
				  sh 'docker run --name zomato-app -d -p 8085:3000 $DOCKER_IMAGE:$DOCKER_TAG'
				}
			}
		}
	}
			
			
